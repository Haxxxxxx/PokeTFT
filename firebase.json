{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": ["npm --prefix functions install", "npm --prefix functions run build"]
  },
  "auth": {
    "providers": {
      "anonymous": true
    }
  },
  "hosting": [
    {
      "target": "landing",
      "public": "out-landing",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        }
      ]
    },
    {
      "target": "game",
      "public": "out",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "comment": "Serve the static native-auth bridge page.",
          "source": "/native-auth",
          "destination": "/native-auth.html"
        },
        {
          "comment": "Serve the static download page.",
          "source": "/download",
          "destination": "/download.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "comment": "Default: never cache — stale index.html points at old JS chunks.",
          "source": "**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "comment": "Hashed build assets are immutable.",
          "source": "/_next/static/**",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "comment": "Mirrored Pokémon sprites.",
          "source": "/sprites/**",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        },
        {
          "comment": "Mirrored Pokémon cries (audio).",
          "source": "/cries/**",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
          ]
        }
      ]
    }
  ]
}
