{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && $uid === auth.uid",
        "username":      { ".validate": "newData.isString() && newData.val().length <= 16" },
        "usernameLower": { ".validate": "newData.isString() && newData.val().length <= 16" },
        "friends": {
          "$fid": { ".write": "auth != null && ($uid === auth.uid || $fid === auth.uid)" }
        },
        "invites": {
          "$code": {
            ".write": "auth != null && (root.child('users').child($uid).child('friends').child(auth.uid).exists() || (!newData.exists() && $uid === auth.uid))"
          }
        }
      }
    },
    "usernames": {
      "$lower": {
        ".read": "auth != null",
        ".write": "auth != null && ((newData.exists() && newData.val() === auth.uid && (!data.exists() || data.val() === auth.uid)) || (!newData.exists() && data.val() === auth.uid))"
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      ".indexOn": ["rating"],
      "$uid": {
        ".write": "auth != null && $uid === auth.uid",
        "rating":   { ".validate": "newData.isNumber()" },
        "username": { ".validate": "newData.isString() && newData.val().length <= 16" }
      }
    },
    "priv": {
      "$code": {
        "$uid": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "lobbies": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$code": {
        ".write": "auth != null && (root.child('games').child($code).child('meta/hostUid').val() === auth.uid || (!newData.exists() && !root.child('games').child($code).exists()))",
        "host":    { ".validate": "newData.isString() && newData.val().length <= 24" },
        "players": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
        "max":     { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 8" }
      }
    },
    "games": {
      "$code": {
        ".read": "auth != null",
        ".indexOn": ["updatedAt"],
        ".write": "auth != null && (!data.exists() || (!newData.exists() && data.child('meta/hostUid').val() === auth.uid))",

        "meta": {
          ".write": "auth != null && (!data.parent().child('meta/hostUid').exists() || data.parent().child('meta/hostUid').val() === auth.uid || (newData.child('hostUid').val() === auth.uid && (!data.child('hostBeat').exists() || data.child('hostBeat').val() < now - 3000)))",
          "phase": { ".validate": "newData.val().matches(/^(lobby|planning|combat|carousel|over)$/)" },
          "stage": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 50" },
          "round": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 12" }
        },

        "invited":  { ".write": "auth != null" },
        "combat":   { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },
        "carousel": { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },
        "rules":    { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },

        "players": {
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)",
            "name":  { ".validate": "newData.isString() && newData.val().length <= 24" },
            "hp":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500" },
            "level": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10" }
          }
        }
      }
    }
  }
}
