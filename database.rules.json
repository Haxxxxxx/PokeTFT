{
  "rules": {
    "meta_learn": {
      "byMode": {
        "$mode": {
          "comp": {
            ".read": "auth != null",
            ".write": "auth != null",
            "$type": {
              "n": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "s": { ".validate": "newData.isNumber()" }
            }
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        "username":        { ".write": "auth != null && $uid === auth.uid", ".validate": "newData.isString() && newData.val().length <= 16" },
        "usernameLower":   { ".write": "auth != null && $uid === auth.uid", ".validate": "newData.isString() && newData.val().length <= 16" },
        "photoURL":        { ".write": "auth != null && $uid === auth.uid", ".validate": "newData.isString() && newData.val().length <= 512" },
        "online":          { ".write": "auth != null && $uid === auth.uid" },
        "currentGame":     { ".write": "auth != null && $uid === auth.uid" },
        "createdAt":       { ".write": "auth != null && $uid === auth.uid && !data.exists()" },
        "ultimateBotWins": { ".write": "auth != null && $uid === auth.uid", ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000 && (!data.exists() || newData.val() === data.val() + 1)" },
        "rating":          { ".write": false },
        "history":         { ".write": false },
        "typeAff": {
          ".write": "auth != null && $uid === auth.uid",
          "$type": { ".validate": "newData.isNumber() && newData.val() >= 0" }
        },
        "ghost": { ".write": "auth != null && $uid === auth.uid" },
        "friends": {
          "$fid": { ".write": "auth != null && ($uid === auth.uid || $fid === auth.uid)" }
        },
        "invites": {
          "$code": {
            ".write": "auth != null && (root.child('users').child($uid).child('friends').child(auth.uid).exists() || (!newData.exists() && $uid === auth.uid))"
          }
        },
        "$other": { ".write": false }
      }
    },
    "usernames": {
      "$lower": {
        ".read": "auth != null",
        ".write": "auth != null && ((newData.exists() && newData.val() === auth.uid && (!data.exists() || data.val() === auth.uid)) || (!newData.exists() && data.val() === auth.uid))"
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      ".indexOn": ["rating"],
      "$uid": {
        ".write": false
      }
    },
    "priv": {
      "$code": {
        "$uid": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "lobbies": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$code": {
        ".write": "auth != null && (root.child('games').child($code).child('meta/hostUid').val() === auth.uid || (!newData.exists() && !root.child('games').child($code).exists()))",
        "host":    { ".validate": "newData.isString() && newData.val().length <= 24" },
        "players": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
        "max":     { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 8" }
      }
    },
    "games": {
      "$code": {
        ".read": "auth != null",
        ".indexOn": ["updatedAt"],
        ".write": "auth != null && (!data.exists() || (!newData.exists() && data.child('meta/hostUid').val() === auth.uid))",

        "meta": {
          ".write": "auth != null && (!data.parent().child('meta/hostUid').exists() || data.parent().child('meta/hostUid').val() === auth.uid || (newData.child('hostUid').val() === auth.uid && (!data.child('hostBeat').exists() || data.child('hostBeat').val() < now - 3000)))",
          "phase": { ".validate": "newData.val().matches(/^(lobby|planning|combat|carousel|over)$/)" },
          "stage": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 50" },
          "round": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 12" }
        },

        "invited":  { ".write": "auth != null && (root.child('games').child($code).child('players').child(auth.uid).exists() || !newData.exists())" },
        "combat":   { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },
        "carousel": { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },
        "rules":    { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },
        "teams":    { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)",
          "$tid": { "hp": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500" } } },
        "ghost":    { ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)" },
        "transfers": {
          ".write": "auth != null && (!root.child('games').child($code).child('meta/hostUid').exists() || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)",
          "$toUid": {
            ".read": "auth != null && $toUid === auth.uid",
            "$tid": {
              ".write": "auth != null && ((!newData.exists() && $toUid === auth.uid) || (newData.exists() && auth.uid !== $toUid && root.child('games').child($code).child('players').child(auth.uid).child('teamId').isNumber() && root.child('games').child($code).child('players').child(auth.uid).child('teamId').val() === root.child('games').child($code).child('players').child($toUid).child('teamId').val()))",
              ".validate": "newData.hasChild('kind') && newData.hasChild('from') && (!newData.hasChild('gold') || (newData.child('gold').isNumber() && newData.child('gold').val() >= 0 && newData.child('gold').val() <= 60))"
            }
          }
        },

        "players": {
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('games').child($code).child('meta/hostUid').val() === auth.uid)",
            "name":  { ".validate": "newData.isString() && newData.val().length <= 24" },
            "hp":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500" },
            "level": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10" },
            "gold":  { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 999)" },
            "place": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 8)" },
            "board": { ".validate": "!newData.exists() || !newData.hasChild('40')" },
            "bench": { ".validate": "!newData.exists() || !newData.hasChild('40')" },
            "teamId": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 4)" },
            "augments": {
              ".validate": "!newData.exists() || !newData.hasChild('3')",
              "$i": { ".validate": "newData.isString() && newData.val().length <= 24" }
            }
          }
        }
      }
    }
  }
}
