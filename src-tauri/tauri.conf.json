{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PokéTFT",
  "version": "0.1.0",
  "identifier": "app.poketft.arena",
  "build": {
    "frontendDist": "shell",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PokéTFT",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["poketft"]
      },
      "mobile": [
        {
          "scheme": ["poketft"],
          "appLink": false
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
